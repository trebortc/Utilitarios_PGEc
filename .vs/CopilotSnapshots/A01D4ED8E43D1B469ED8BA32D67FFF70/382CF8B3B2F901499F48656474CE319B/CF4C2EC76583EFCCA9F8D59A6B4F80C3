        public static Bitmap GenerateQRCode(string content, int width = 250)
        {
            QRCodeGenerator qrGenerator = new QRCodeGenerator();
            QRCodeData qrCodeData = qrGenerator.CreateQrCode(content, QRCodeGenerator.ECCLevel.Q);
            QRCode qrCode = new QRCode(qrCodeData);

            Bitmap qrCodeImage = qrCode.GetGraphic(width);
            return qrCodeImage;
        }
        public static Bitmap GenerateQRCodeURL(Url url, int width = 100)
        {
            QRCodeGenerator qrGenerator = new QRCodeGenerator();
            QRCodeData qrCodeData = qrGenerator.CreateQrCode(url, QRCodeGenerator.ECCLevel.H);
            QRCode qrCode = new QRCode(qrCodeData);

            string archivo = @"Resources\\QrPGE.png";
            string rutaRelativa = Path.GetFullPath(archivo);

            Bitmap qrCodeImage = qrCode.GetGraphic(width, System.Drawing.Color.Black, System.Drawing.Color.White, (Bitmap)Bitmap.FromFile(rutaRelativa));
            return qrCodeImage;
        }
        public static List<string> CargarListadoDeParticipantes(string urlArchivo)
        {
            int indice = 1;
            List<string> participantes = new List<string>();

            try
            {
                if (string.IsNullOrWhiteSpace(urlArchivo) || !File.Exists(urlArchivo))
                {
                    // usar Console.WriteLine para evitar dependencias UI en modo consola
                    Console.WriteLine("Archivo no encontrado: " + urlArchivo);
                    return new List<string>();
                }

                using (var wb = new XLWorkbook(urlArchivo))
                {
                    var ws = wb.Worksheet(1);

                    // Leer filas hasta encontrar una celda vacía en la columna 1
                    while (true)
                    {
                        var control = ws.Cell(indice, 1).GetString();
                        if (string.IsNullOrWhiteSpace(control)) break;

                        if (indice == 1)
                        {
                            nombreCurso = ws.Cell(indice, 2).GetString()?.Trim() ?? string.Empty;
                            participantes.Add(nombreCurso);
                        }
                        else if (indice == 2)
                        {
                            // omitir segunda fila según lógica original
                        }
                        else
                        {
                            string nombreUsuario = ws.Cell(indice, 2).GetString()?.Trim() ?? string.Empty;
                            if (!string.IsNullOrEmpty(nombreUsuario)) participantes.Add(nombreUsuario);
                        }

                        indice++;
                        if (indice > 200000) break; // seguridad
                    }
                }

                return participantes;
            }
            catch (Exception ex)
            {
                // Mostrar mensaje y stacktrace en consola para diagnóstico
                Console.WriteLine("Error leyendo archivo Excel: " + ex.Message + "\n" + ex.StackTrace);
                return new List<string>();
            }
        }

