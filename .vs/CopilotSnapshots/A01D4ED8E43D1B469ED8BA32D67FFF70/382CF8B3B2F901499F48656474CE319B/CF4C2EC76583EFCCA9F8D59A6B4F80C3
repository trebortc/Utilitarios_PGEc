        public static void Main2(string[] args)
        {
            // Ruta del recurso compartido (sin el "file://")
            string origen = @"\\10.12.1.7\eventos pge";

            // Carpeta local donde guardar
            string destino = @"C:\descargas";

            // Crear carpeta local si no existe
            if (!Directory.Exists(destino))
            {
                Directory.CreateDirectory(destino);
            }

            try
            {
                // Copiar todos los archivos del directorio raíz
                foreach (string archivo in Directory.GetFiles(origen))
                {
                    string nombreArchivo = Path.GetFileName(archivo);
                    string destinoArchivo = Path.Combine(destino, nombreArchivo);

                    File.Copy(archivo, destinoArchivo, true);
                    Console.WriteLine($"Copiado: {nombreArchivo}");
                }

                // Si quieres también incluir subcarpetas:
                foreach (string carpeta in Directory.GetDirectories(origen, "*", SearchOption.AllDirectories))
                {
                    string rutaRelativa = carpeta.Substring(origen.Length).TrimStart('\\');
                    string nuevaCarpetaDestino = Path.Combine(destino, rutaRelativa);

                    if (!Directory.Exists(nuevaCarpetaDestino))
                    {
                        Directory.CreateDirectory(nuevaCarpetaDestino);
                    }

                    foreach (string archivo in Directory.GetFiles(carpeta))
                    {
                        string nombreArchivo = Path.GetFileName(archivo);
                        string destinoArchivo = Path.Combine(nuevaCarpetaDestino, nombreArchivo);

                        File.Copy(archivo, destinoArchivo, true);
                        Console.WriteLine($"Copiado: {destinoArchivo}");
                    }
                }

                Console.WriteLine("✅ Descarga completa.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Error: {ex.Message}");
            }
        }
