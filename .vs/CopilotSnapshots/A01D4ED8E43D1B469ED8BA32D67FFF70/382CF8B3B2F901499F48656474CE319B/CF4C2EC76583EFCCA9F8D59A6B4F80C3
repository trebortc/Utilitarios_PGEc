        public static bool EsCorreoValido(string email)
        {
            try
            {
                var addr = new MailAddress(email);
                return addr.Address == email;
            }
            catch
            {
                return false;
            }
        }

        public static List<string> ObtenerCorreosArchivo()
        {
            var emails = new List<string>();

            using (var workbook = new XLWorkbook("subsc_agosto_2025.xlsx"))
            {
                var worksheet = workbook.Worksheet(1); // primera hoja
                foreach (var row in worksheet.RowsUsed().Skip(1)) // omite la primera fila
                {
                    string correo = row.Cell(3).GetString(); // columna A
                    emails.Add(correo);
                }
            }

            return emails;
        }
